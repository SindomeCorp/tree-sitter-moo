{
  "name": "tree-sitter-moo",
  "version": "0.2.12",
  "description": "Tree-sitter grammar for ToastStunt/LambdaMOO verb code.",
  "homepage": "https://github.com/SindomeCorp/tree-sitter-moo#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SindomeCorp/tree-sitter-moo.git"
  },
  "bugs": {
    "url": "https://github.com/SindomeCorp/tree-sitter-moo/issues"
  },
  "type": "commonjs",
  "main": "bindings/node",
  "types": "bindings/node",
  "scripts": {
    "generate": "tree-sitter generate",
    "build:wasm": "node -e \"require('fs').mkdirSync('dist', { recursive: true })\" && tree-sitter build --wasm -o dist/tree-sitter-moo.wasm",
    "test": "npm run test:corpus",
    "test:corpus": "env HOME=/tmp TREE_SITTER_DIR=/tmp tree-sitter test --config-path tree-sitter-config.json",
    "test:fixtures": "npm run validate:fixtures",
    "test:queries": "node scripts/validate-queries.js",
    "test:go": "node scripts/test-go.js",
    "test:rust": "node scripts/test-rust.js",
    "test:python": "node scripts/test-python.js",
    "test:c": "node scripts/test-c.js",
    "test:wasm": "node scripts/test-wasm.js",
    "test:smoke": "npm run smoke:native && npm run test:go && npm run test:rust && npm run test:python && npm run test:c && npm run test:wasm",
    "test:generated": "node scripts/check-generated.js",
    "test:pr": "npm run test:corpus && npm run test:queries && npm run test:fixtures && npm run test:smoke && npm run test:generated",
    "parse:fixtures": "npm run validate:fixtures",
    "import:fixtures": "node scripts/import-fixtures.js",
    "import:fixtures:all": "node scripts/import-fixtures.js --all",
    "validate:fixtures": "env HOME=/tmp TREE_SITTER_DIR=/tmp node scripts/validate-fixtures.js fixtures/valid",
    "validate:wasm": "node scripts/validate-wasm.js",
    "smoke:native": "node scripts/smoke-native.js",
    "smoke:package": "node scripts/smoke-package.js",
    "ci": "npm run test:pr && npm run build:wasm && npm run validate:wasm",
    "install": "node-gyp-build",
    "prepare:package": "npm run generate && npm run build:wasm",
    "prebuildify": "prebuildify --napi --strip"
  },
  "keywords": [
    "tree-sitter",
    "moo",
    "lambdamoo",
    "toaststunt"
  ],
  "files": [
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "TESTING.md",
    "RELEASE.md",
    "ROADMAP.md",
    "SECURITY.md",
    "docs/**",
    "grammar.js",
    "tree-sitter.json",
    "binding.gyp",
    "prebuilds/**",
    "bindings/node/*",
    "queries/**",
    "src/**",
    "dist/**"
  ],
  "exports": {
    ".": "./bindings/node/index.js",
    "./wasm": "./dist/tree-sitter-moo.wasm",
    "./queries/facts": "./queries/facts.scm",
    "./queries/highlights": "./queries/highlights.scm",
    "./queries/tags": "./queries/tags.scm",
    "./package.json": "./package.json"
  },
  "author": "SindomeCorp <slither@sindome.com>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "prebuildify": "^6.0.0",
    "tree-sitter": "^0.25.0",
    "tree-sitter-cli": "^0.25.10"
  },
  "tree-sitter": [
    {
      "scope": "source.moo",
      "file-types": [
        "moo"
      ],
      "highlights": "queries/highlights.scm"
    }
  ],
  "dependencies": {
    "node-addon-api": "^8.8.0",
    "node-gyp-build": "^4.8.0"
  },
  "peerDependencies": {
    "tree-sitter": "^0.25.0"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  }
}
